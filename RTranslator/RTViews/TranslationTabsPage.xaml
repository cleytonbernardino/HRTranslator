<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="RTranslator.RTViews.TranslationTabsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:RTranslator.Models"
    xmlns:helps="using:RTranslator.Helpers"
    mc:Ignorable="d">

    <Page.Resources>
        <DataTemplate x:Key="FolderTemplate" x:DataType="models:ExploreItem">
            <TreeViewItem ItemsSource="{x:Bind Children}" IsExpanded="True">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xED41;" FontSize="16" Foreground="{ThemeResource SystemAccentColor}"/>
                    <TextBlock Text="{x:Bind Name}" VerticalAlignment="Center"/>
                </StackPanel>
            </TreeViewItem>
        </DataTemplate>

        <DataTemplate x:Key="FileTemplate" x:DataType="models:ExploreItem">
            <TreeViewItem>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE8A5;" FontSize="16"/>
                    <TextBlock Text="{x:Bind Name}" VerticalAlignment="Center"/>
                </StackPanel>
            </TreeViewItem>
        </DataTemplate>

        <helps:ExplorerItemTemplateSelector x:Key="FileTemplateSelector"
            FolderTemplate="{StaticResource FolderTemplate}"
            FileTemplate="{StaticResource FileTemplate}" />
    </Page.Resources>
    
    <Page.KeyboardAccelerators>
        <KeyboardAccelerator Modifiers="Control" Key="Tab" Invoked="ChangeFileAccelerator_Invoked"/>
    </Page.KeyboardAccelerators>
    
    <Grid>
        <TabView  x:Name="Tab_Root"
                  TabWidthMode="SizeToContent"
                  AddTabButtonClick="TabView_AddTabButtonClick" 
                  TabCloseRequested="TabView_TabCloseRequested"
                  Loaded="TabView_Loaded"/>

        <Grid x:Name="FileSwitcherOverlay" Visibility="Collapsed" Background="#80000000"
              PointerPressed="FileSwitcherOverlay_PointerPressed">
            <Border Width="450" Height="550" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" 
                    CornerRadius="8" Padding="16" HorizontalAlignment="Center" VerticalAlignment="Center">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBox x:Name="SearchInputBox" PlaceholderText="Search..." Margin="0,0,0,16"/>

                    <TreeView x:Name="FileTreeView" 
                                Grid.Row="1"
                                ItemsSource="{x:Bind ViewModel.ExploreItem.Children, Mode=OneWay}"
                                ItemTemplateSelector="{StaticResource FileTemplateSelector}" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>

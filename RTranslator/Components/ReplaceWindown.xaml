<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="RTranslator.Components.ReplaceWindown"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <x:Double x:Key="IconFontSize">16</x:Double>
    </UserControl.Resources>
    
    <Border
        Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
        BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
        MaxWidth="900"
        MinWidth="200"
        BorderThickness="1"
        CornerRadius="8"
        Padding="10">
        <Grid ColumnSpacing="5"
              RowSpacing="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="40" />
                <ColumnDefinition Width="*" MinWidth="100"/>
                <ColumnDefinition Width="210" />
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Button Grid.Column="0" Grid.Row="0"
                    Click="Btn_Expander_Click"
                    Style="{ThemeResource SubtleButtonStyle}">
                <FontIcon Glyph="&#xE70D;"/>
            </Button>

            <TextBox Grid.Column="1" Grid.Row="0"
                     x:Uid="\RTranslator\RTResources\PLACE_SEARCH"/>

            <StackPanel Grid.Column="2" Grid.Row="0"
                        Orientation="Horizontal">
                <Button Style="{ThemeResource SubtleButtonStyle}">
                    <FontIcon Glyph="&#xE74B;" FontSize="{StaticResource IconFontSize}"/>
                </Button>

                <Button Style="{ThemeResource SubtleButtonStyle}">
                    <FontIcon Glyph="&#xE74A;" FontSize="{StaticResource IconFontSize}"/>
                </Button>

                <Button Style="{ThemeResource SubtleButtonStyle}">
                    <FontIcon Glyph="&#xE9E9;" FontSize="{StaticResource IconFontSize}"/>
                </Button>

                <Button Style="{ThemeResource SubtleButtonStyle}"
                        Foreground="Red"
                        Click="Btn_Close_Click">
                    <FontIcon Glyph="&#xE711;" FontSize="{StaticResource IconFontSize}"/>
                </Button>
            </StackPanel>
            <TextBox Grid.Column="1" Grid.Row="1"
                     x:Name="Txb_Replace"
                     x:Uid="\RTranslator\RTResources\PLACE_REPLACE"/>

            <StackPanel Grid.Column="2" Grid.Row="1"
                        x:Name="Skp_ReplaceBtn"
                        Orientation="Horizontal"
                        Spacing="5">

                <Button x:Uid="\RTranslator\RTResources\BTN_REPLACE"
                        Click="Btn_Replace_Click"/>
                <Button x:Uid="\RTranslator\RTResources\BTN_REPLACE_ALL"
                        Click="Btn_ReplaceAll_Click"/>

            </StackPanel>
        </Grid>
    </Border>
</UserControl>